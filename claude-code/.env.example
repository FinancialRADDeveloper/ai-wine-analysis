# ============================================================================
# Sommelier Platform - Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ============================================================================

# Environment
ENVIRONMENT=dev

# Database (defaults work with docker-compose.yml)
DATABASE_URL=postgresql://sommelier:sommelier_dev@localhost:5432/sommelier

# AWS (LocalStack for local dev)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=eu-west-2
S3_LANDING_BUCKET=sommelier-landing

# LLM API keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Wine Society credentials (for order history scraper)
WINE_SOCIETY_EMAIL=your@email.com
WINE_SOCIETY_PASSWORD=your_password
